# RITA environment configuration
RITA_ENV=development

# JWT secret — required in staging/production (min 32 chars)
RITA_JWT_SECRET=change-me-in-production

# Data paths — set these to override the defaults in config/base.yaml.
# In Docker/k8s these are injected via ConfigMap or -e flags.
# Default layout (relative to project root):
#   data/raw/{INSTRUMENT}/    — source CSVs, read-only
#   data/input/{INSTRUMENT}/  — processed CSVs ready for model
#   data/output/{INSTRUMENT}/ — backtest results, risk timeline, trade events
#   models/{INSTRUMENT}/      — trained model ZIPs
RITA_DATA_RAW_DIR=/path/to/data/raw
RITA_DATA_INPUT_DIR=/path/to/data/input
RITA_DATA_OUTPUT_DIR=/path/to/data/output
RITA_MODEL_PATH=/path/to/models

# Optional overrides
RITA_SERVER__PORT=8000

# Chat assistant — local sentence-transformers model (no HuggingFace download at runtime).
# Point to the snapshot folder of the already-downloaded all-MiniLM-L6-v2 model.
RITA_CHAT__EMBED_MODEL_PATH=C:\Users\Sandeep\.cache\huggingface\hub\models--sentence-transformers--all-MiniLM-L6-v2\snapshots\c9745ed1d9f207416be6d2e6f8de32d1f16199bf
